from dotenv import load_dotenv

load_dotenv()


from langchain_ollama import ChatOllama

model = ChatOllama(model="qwen3:14b", temperature=0)


from langchain_community.utilities import SQLDatabase

db = SQLDatabase.from_uri("sqlite:///resources/Chinook.db")


from langchain.tools import tool

@tool
def sql_query(query: str) -> str:

    """Obtain information from the database using SQL queries"""

    try:
        return db.run(query)
    except Exception as e:
        return f"Error: {e}"

sql_query.invoke("SELECT * FROM Artist LIMIT 10")


from langchain.agents import create_agent

agent = create_agent(
    model=model,
    tools=[sql_query]
)


from langchain.messages import HumanMessage

question = HumanMessage(content="Who is the most popular artist beginning with 'S' in this database?")

response = agent.invoke(
    {"messages": [question]}
)


from pprint import pprint

pprint(response['messages'])


print(response["messages"][-3].tool_calls[0]['args']['query'])


print(response["messages"][-1].content)





from langchain.messages import HumanMessage

question = HumanMessage(content="""
    Use the sql code below to query the database
    
    ```sql
    SELECT Artist.name, COUNT(Track.TrackID) AS track_count
    FROM Artist
    JOIN Track ON Artist.ArtistID = Track.ArtistID
    WHERE Artist.name LIKE 'S%'
    GROUP BY Artist.name
    ORDER BY track_count DESC
    LIMIT 1;
    ```
"""
)

response = agent.invoke(
    {"messages": [question]}
)


from pprint import pprint

pprint(response['messages'])








